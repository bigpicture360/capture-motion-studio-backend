# AWS
AWS_DEFAULT_REGION=us-east-1
SQS_QUEUE_URL=
VIDEO_BRANDING_SQS_QUEUE_URL=
OUTPUT_BUCKET=
OUTPUT_PREFIX=bigpicture360.net/renders

# Render worker
POLL_INTERVAL=5
MAX_CONCURRENT=1
VIDEO_BRANDING_MAX_CONCURRENT=1
VISIBILITY_TIMEOUT=3600
VIDEO_BRANDING_VISIBILITY_TIMEOUT=3600
MIN_FREE_DISK_GB=2
LOG_LEVEL=INFO
FFMPEG_MIN_TIMEOUT_SECONDS=1800
FFMPEG_MAX_TIMEOUT_SECONDS=43200
VIDEO_BRANDING_FFMPEG_TIMEOUT_SECONDS=7200
FFMPEG_VISIBILITY_BUFFER_SECONDS=900

# Callbacks
RENDER_CALLBACK_URL=
RENDER_WORKER_SECRET=
